{
  "name": "javstash-proxy",
  "version": "1.0.0",
  "description": "GraphQL proxy for javstash.org with automatic Japanese-to-Chinese translation",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "next dev -p 3456",
    "build": "next build",
    "start": "next start -p 3456",
    "fill:missing-raw-response": "node scripts/fill-missing-raw-response.mjs",
    "typecheck": "tsc --noEmit",
    "fix:cover-urls": "node scripts/fix-cover-urls.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@gsap/react": "^2.1.2",
    "@libsql/client": "^0.17.2",
    "@tailwindcss/postcss": "^4.2.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gsap": "^3.14.2",
    "lucide-react": "^1.7.0",
    "motion": "^12.23.12",
    "next": "^16.2.1",
    "next-themes": "^0.4.6",
    "ogl": "^1.0.11",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "^4.1.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "keywords": [
    "graphql",
    "proxy",
    "japanese",
    "chinese",
    "translation"
  ],
  "author": "",
  "license": "ISC"
}
