# JavStash API Key (required)
JAVSTASH_API_KEY=your_api_key_here

# Turso Database (required)
TURSO_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your_auth_token_here

# DeepLX Translation API (optional)
DEEPLX_API_URL=http://localhost:8080/translate

# Admin Dashboard Password (required for web UI)
ADMIN_PASSWORD=your_admin_password_here
